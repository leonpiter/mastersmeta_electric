{
  "name": "see-electrical-lite",
  "version": "0.0.0",
  "private": true,
  "description": "Офлайн ГОСТ-редактор электрических схем щитов (агентная разработка)",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @see/desktop dev",
    "build": "pnpm --filter @see/desktop build",
    "test": "pnpm --filter @see/core test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm verify"
  },
  "lint-staged": {
    "*.{ts,js,json,css,html}": "prettier --write"
  }
}
