{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://see-electrical-lite/schemas/symbol.schema.json",
  "title": "SymbolDef (*.symbol.json)",
  "description": "Открытый формат УГО. Канонический контракт; формальная валидация в CI подключается в S12 (ajv). В рантайме core валидирует через validateSymbol().",
  "type": "object",
  "required": ["id", "name", "category", "componentCode", "kind", "graphics", "pins"],
  "additionalProperties": false,
  "properties": {
    "formatVersion": {
      "type": "integer",
      "description": "Версия формата для миграций (текущая — 1)."
    },
    "id": { "type": "string", "minLength": 1, "description": "Стабильный id, напр. gost.qf" },
    "name": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "componentCode": {
      "type": "string",
      "minLength": 1,
      "description": "Префикс позобозначения по ГОСТ 2.710 (QF/QS/KM/...)."
    },
    "kind": {
      "type": "string",
      "enum": [
        "coil",
        "component",
        "component-aux",
        "contact-no",
        "contact-nc",
        "terminal",
        "connector",
        "page-connector",
        "black-box"
      ]
    },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "x", "y"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "graphics": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "x1", "y1", "x2", "y2"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "line" },
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["type", "x", "y", "w", "h"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "rect" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["type", "cx", "cy", "r"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "circle" },
              "cx": { "type": "number" },
              "cy": { "type": "number" },
              "r": { "type": "number" }
            }
          },
          {
            "type": "object",
            "required": ["type", "x", "y", "text"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "text" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "text": { "type": "string" },
              "size": { "type": "number" },
              "anchor": { "type": "string", "enum": ["start", "middle", "end"] }
            }
          }
        ]
      }
    }
  }
}
